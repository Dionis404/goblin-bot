# --- Telegram ---
BOT_TOKEN=your_telegram_bot_token_from_botfather
# Прокси для доступа к Telegram (если регион блокирует api.telegram.org).
# Пусто = напрямую. Пример SOCKS5: socks5://127.0.0.1:10808
TELEGRAM_PROXY=

# --- PostgreSQL (БД sfl) ---
# В Docker на shared-net хост = имя контейнера postgres (например postgres-main).
# Для локального теста — IP/домен сервера БД.
DB_HOST=postgres-main
DB_PORT=5432
DB_NAME=sfl
DB_USER=goblin
DB_PASSWORD=your_db_password

# --- PostgreSQL сайта goblincodex (БД goblincodex, таблица telegram_posts) ---
# Отдельная БД/контейнер от postgres-main.
GOBLINCODEX_DB_HOST=postgres
GOBLINCODEX_DB_PORT=5432
GOBLINCODEX_DB_NAME=goblincodex
GOBLINCODEX_DB_USER=goblin
GOBLINCODEX_DB_PASSWORD=your_goblincodex_db_password

# Канал, посты которого зеркалируются в telegram_posts (без @)
TELEGRAM_POSTS_CHANNEL=URGSFL

# --- Sunflower Land community API ---
SFL_API_BASE=https://api.sunflower-land.com
# Ключ авторизации (передаётся в заголовке x-api-key)
SFL_API_KEY=your_sfl_api_key
FARM_URL_TEMPLATE=https://sunflower-land.com/play/#/visit/{farm_id}
# Прокси для SFL API. Пусто = унаследует TELEGRAM_PROXY.
SFL_PROXY=

# --- Защита от rate limit / спама (консервативные значения) ---
API_RATE_PER_SEC=2        # запросов/сек к SFL API на весь бот
API_CONCURRENCY=1         # одновременных запросов к API
USER_COOLDOWN_SEC=5       # пауза между запросами одного пользователя (сек)
API_MAX_RETRIES=3         # повторов при 429
API_RETRY_BACKOFF=2       # базовая пауза backoff (сек)
